# Required
DISCORD_TOKEN=

# Optional — bot owner (admin-only commands, nword/bday owner checks, etc.)
BOT_OWNER_ID=

# Optional — spam blacklist immunity & antinuke admin role
ADMIN_ROLE_ID=

# Optional — logging channels (skip if unset; related logs are skipped)
BLACKLIST_LOG_CHANNEL_ID=
GUILD_JOIN_LOG_CHANNEL_ID=
BLACKLIST_COMMAND_LOG_CHANNEL_ID=
COMMAND_ERROR_LOG_CHANNEL_ID=

# Optional — support / community invite used in welcome & help
SUPPORT_SERVER_URL=https://discord.com

# Optional — antinuke override codewords user (strive / strive+1)
ANTINUKE_OVERRIDE_USER_ID=

# Optional — ticket system (panel command owner = BOT_OWNER_ID)
TICKET_STAFF_ROLE_ID=
TICKET_SUPPORT_CATEGORY_ID=
TICKET_BUGS_CATEGORY_ID=

# Optional — help embed “Website” button
BOT_WEBSITE_URL=

# Optional — crypto premium check (guild the bot is in + premium role)
CRYPTO_BOT_GUILD_ID=
CRYPTO_PREMIUM_ROLE_ID=

# Optional — wallet verification frontend base URL (shown in crypto commands)
VERIFICATION_URL=

# Verification HTTP API (crypto wallet connect)
VERIFICATION_API_PORT=3001
VERIFICATION_API_SECRET=
VERIFICATION_FRONTEND_URL=*

# Optional — higher Etherscan limits for ETH balance checks
ETHERSCAN_API_KEY=

# Optional — Railway persistent volume for SQLite
RAILWAY_VOLUME_MOUNT_PATH=

# Optional — credit line in welcome embed (index) and botinformation when set (markdown OK)
DEVELOPER_CREDIT_LINE=

# Optional — burnwelcome template: channel mentions (same guild as the welcome message)
WELCOME_SUPPORT_CHANNEL_ID=
WELCOME_GUIDE_CHANNEL_ID=
WELCOME_SUGGESTIONS_CHANNEL_ID=
WELCOME_UPDATES_CHANNEL_ID=
